{
  "$id": "backlog_item@1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["key", "status"],
  "additionalProperties": false,
  "properties": {
    "key": { "type": "string", "pattern": "^[A-Z]+-[0-9]{3,}$" },
    "status": { "enum": ["ready", "next", "later", "in_progress", "done", "blocked"] },
    "sprint": { "type": "string", "description": "Sprint key this ticket belongs to (e.g. S1); unset = general backlog, not in any sprint." },
    "assignee": { "type": "string", "description": "Who should act on this, e.g. 'me', 'agent', or a name. Personal-backlog views filter on it (hide agent-owned tasks)." },
    "priority": { "enum": ["low", "normal", "high"] },
    "acceptance": { "type": "string" },
    "estimate": { "type": "string" },
    "blocked_by": { "type": "array", "items": { "type": "string" } }
  }
}
